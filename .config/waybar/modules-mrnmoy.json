{
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },

  "hyprland/window": {
    "rewrite": {
      "(.*) - Zen Browser": "$1",
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },

  "custom/appmenu": {
    "format": "у°Ј‡",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings",
    "on-click": "rofi -show drun -replace & sleep 0.2; hyprctl dispatch focuswindow '^(Rofi)'",
    "on-click-right": "~/.config/notscripter/scripts/keybindings.sh",
    "tooltip": false
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "у±…«",
      "none": "у°‚љ",
      "dnd-notification": "у±…«",
      "dnd-none": "у°‚›",
      "inhibited-notification": "п‚ў",
      "inhibited-none": "п‚ў",
      "dnd-inhibited-notification": "п‚ў",
      "dnd-inhibited-none": "п‚ў"
    },
    "return-type": "json",
    "exec-if": "which makoctl",
    "exec": "$HOME/.local/bin/mako.sh",
    "on-click": "$HOME/.local/bin/rofi-mako.sh",
    "on-click-middle": "$HOME/.local/bin/mako.sh --clear && pkill -RTMIN+8 waybar",
    "on-click-right": "makoctl mode -t do-not-disturb && pkill -RTMIN+8 waybar",
    "signal": 8,
    "escape": true
  },

  "tray": {
    "icon-size": 24,
    "spacing": 8
  },

  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "у°Ґ” {0:%I:%M %p}",
    "format-alt": "у°Ґ” {0:%I:%M %p}  пЃі {0:%d-%m-%Y}"
  },

  "network": {
    "format": "{ifname}",
    "format-wifi": "п‡«  {signalStrength}% п„є {bandwidthDownBytes} п„№ {bandwidthUpBytes} ",
    "format-ethernet": "пЉ‡  п„є {bandwidthDownBytes} п„№ {bandwidthUpBytes} ",
    "format-disconnected": "у°І› ",
    "tooltip-format": "пЉ‡  {ifname} via {gwaddri}",
    "tooltip-format-wifi": "п‡«   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "пѓЃ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "interval": 1,
    "on-click": "nm-connection-editor"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}   {capacity}%",
    "format-charging": "п—§  {capacity}%",
    "format-plugged": "п‡¦  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-icons": ["п‰„ ", "п‰ѓ ", "п‰‚ ", "п‰Ѓ ", "п‰Ђ "]
  },

  "bluetooth": {
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "пЏЃ",
      "deactivated": "пЂЈ"
    },
    "on-click-right": "hyprlock"
  }
}
