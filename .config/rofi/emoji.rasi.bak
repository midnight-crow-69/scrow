@import "colors.rasi"

configuration {
    show-icons:     false;
    font:           "Noto Color Emoji 16";
    modi:           "emoji";
    matching:       "normal";
    sort:           false;

    kb-cancel:              "Escape";
    kb-remove-char-back:    "BackSpace,Shift+BackSpace";
    kb-accept-entry:        "Return,KP_Enter";
    me-select-entry:        "";
    me-accept-entry:        "MousePrimary";
    click-to-exit:          true;
}

window {
    location:           center;
    anchor:             center;
    width:              420px;
    border-width:       1px;
    border-color:       @purple;
    border-radius:      10px;
    padding:            12px;
    background-color:   @bg0;
    transparency:       "real";
}

mainbox {
    children:           [ inputbar, listview ];
    spacing:            8px;
    background-color:   transparent;
}

inputbar {
    children:           [ prompt, entry ];
    spacing:            8px;
    padding:            10px 12px;
    border-radius:      10px;
    background-color:   @bg1;
}

prompt {
    enabled:            true;
    background-color:   transparent;
    text-color:         @purple;
    font:               "JetBrainsMono Nerd Font Bold 13";
}

entry {
    placeholder:        "Search emoji...";
    placeholder-color:  @fg1;
    background-color:   transparent;
    text-color:         @fg0;
    cursor:             text;
    font:               "JetBrainsMono Nerd Font 13";
}

listview {
    columns:            8;
    lines:              6;
    cycle:              true;
    scrollbar:          false;
    spacing:            2px;
    fixed-height:       true;
    background-color:   transparent;
    padding:            4px 0 0 0;
}

element {
    padding:            6px;
    border-radius:      10px;
    cursor:             pointer;
    spacing:            0;
    border-width:       2px;
    border-color:       @bg1;
    background-color:   transparent;
    horizontal-align:   0.5;
    vertical-align:     0.5;
}

element-icon {
    size:               0em;
    background-color:   transparent;
}

element-text {
    background-color:   transparent;
    text-color:         @fg1;
    cursor:             inherit;
    expand:             true;
    horizontal-align:   0.5;
    vertical-align:     0.5;
}

element normal.normal,
element alternate.normal {
    background-color:   transparent;
    text-color:         @fg1;
}

element selected.normal,
element selected.active {
    background-color:   @bg2;
    border-width:       2px;
    border-color:       @purple;
    text-color:         @fg0;
}

element normal.active,
element alternate.active {
    background-color:   transparent;
    text-color:         @fg1;
}

element normal.urgent,
element alternate.urgent {
    background-color:   transparent;
    text-color:         @fg1;
}

element selected.urgent {
    background-color:   transparent;
    text-color:         @fg1;
}
